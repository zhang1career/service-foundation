{
  "openapi": "3.0.3",
  "info": {
    "title": "Config Center API",
    "description": "app_config 对外 HTTP 接口（配置查询）。响应包络为 `{ errorCode, data, message, ... }`：`errorCode === 0` 表示成功。`APP_CONFIG_ENABLED` 为真时：`/api/config/` 挂载健康检查、`pub`、需登录的 `pri`；`/ai/config/pri` 与 `POST /api/config/pri` 为同一视图（兼容旧路径，见 `service_foundation/urls.py`）。\n\n`sf_config.config_entry.public`：**0=private（按 `condition` 与请求 `conditions` 子集匹配）**；**1=public（不按 `condition` 计算，行内 `condition` 须为 `{}`）**。\n`GET /api/config/pub`（无登录）仅合并 **public=1** 行；`POST /api/config/pri`（需登录）合并 **public=1** 与 **public=0** 行。合并顺序按 `ut`、`id` 升序浅合并；缓存键含 `rid` 代际与 `pub`/`pri` 作用域。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "相对当前站点根路径"
    }
  ],
  "tags": [
    {
      "name": "Config",
      "description": "配置中心查询与健康检查"
    }
  ],
  "paths": {
    "/api/config/health": {
      "get": {
        "tags": ["Config"],
        "summary": "健康检查",
        "operationId": "configHealth",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/EnvelopeOk" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "status": { "type": "string", "example": "ok" },
                            "service": { "type": "string", "example": "config" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            },
            "headers": {
              "X-Request-Id": { "$ref": "#/components/headers/XRequestId" },
              "Expires": { "schema": { "type": "string" } }
            }
          }
        }
      }
    },
    "/api/config/pub": {
      "get": {
        "tags": ["Config"],
        "summary": "无登录态：合并配置（仅 public=1 行）",
        "description": "无需登录。调用方密钥与业务配置键须通过 **请求头** 传递（避免出现在 URL、访问日志与 Referer 中）：`X-Config-Access-Key`、`X-Config-Key`。可选查询参数 `conditions` 为 **JSON 对象字符串**（整体须 URL 编码）。仅合并 `config_entry.public=1` 的行；此类行**不按** `condition` 过滤（约定 `condition` 为空字符串）。`public=0` 行不会出现在本接口结果中。成功时 `data` 仅含 `value` 与 `_ids`，**不含** `_explain`。",
        "operationId": "configPub",
        "parameters": [
          {
            "name": "X-Config-Access-Key",
            "in": "header",
            "required": true,
            "description": "已启用调用方的 access key（与 JSON 字段 `access_key` 语义相同）。",
            "schema": { "$ref": "#/components/schemas/AccessKey" }
          },
          {
            "name": "X-Config-Key",
            "in": "header",
            "required": true,
            "description": "业务配置键 `config_key`（与 JSON 字段 `key` 语义相同）。",
            "schema": { "$ref": "#/components/schemas/ConfigKey" }
          },
          {
            "name": "conditions",
            "in": "query",
            "required": false,
            "description": "可选。JSON 对象字符串（例如 `{\"env\":\"prod\",\"region\":\"cn\"}` 编码后传入）。缺省按 `{}` 处理。",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功或参数错误（errorCode≠0 时 HTTP 仍为 200，见包络）",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "allOf": [
                        { "$ref": "#/components/schemas/EnvelopeOk" },
                        {
                          "type": "object",
                          "properties": {
                            "data": { "$ref": "#/components/schemas/ConfigQueryResultPub" }
                          }
                        }
                      ]
                    },
                    { "$ref": "#/components/schemas/EnvelopeError" }
                  ]
                }
              }
            },
            "headers": {
              "X-Request-Id": { "$ref": "#/components/headers/XRequestId" },
              "Expires": { "schema": { "type": "string" }, "description": "成功响应可能带短期 Expires（与 `resp_ok` 一致）" }
            }
          }
        }
      }
    },
    "/api/config/pri": {
      "post": {
        "tags": ["Config"],
        "summary": "登录态：合并配置（public=1 与 private=0 行）",
        "description": "需要已认证用户（DRF Session 或 Basic）。**请求头**须带 `X-Config-Access-Key`（与 `GET /api/config/pub` 同名，已启用调用方）。JSON 体仅含 `key`、可选 `conditions` 对象；body 中的 `access_key` 若存在会被忽略。合并 **public=1** 行（不按 `condition`）与 **public=0** 行（按 `condition` 与 `conditions` 子集匹配）。未登录时返回 403（DRF 默认行为，具体包络见项目异常处理）。",
        "operationId": "configPri",
        "security": [{ "sessionAuth": [] }, { "basicAuth": [] }],
        "parameters": [
          {
            "name": "X-Config-Access-Key",
            "in": "header",
            "required": true,
            "description": "已启用调用方的 access key（与 pub 接口同名头）。",
            "schema": { "$ref": "#/components/schemas/AccessKey" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConfigPriRequestBody" },
              "examples": {
                "minimal": {
                  "summary": "仅默认条件",
                  "value": {
                    "key": "app.feature.flags"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功或参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "allOf": [
                        { "$ref": "#/components/schemas/EnvelopeOk" },
                        {
                          "type": "object",
                          "properties": {
                            "data": { "$ref": "#/components/schemas/ConfigQueryResult" }
                          }
                        }
                      ]
                    },
                    { "$ref": "#/components/schemas/EnvelopeError" }
                  ]
                }
              }
            },
            "headers": {
              "X-Request-Id": { "$ref": "#/components/headers/XRequestId" },
              "Expires": { "schema": { "type": "string" } }
            }
          },
          "403": {
            "description": "未登录或无权限（`IsAuthenticated`）"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sessionid",
        "description": "Django 会话（控制台同源登录后携带 cookie）。"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic（若服务端启用）。"
      }
    },
    "headers": {
      "XRequestId": {
        "description": "请求关联 ID；客户端可传 `X-Request-Id`，成功响应会回显。",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "EnvelopeOk": {
        "type": "object",
        "required": ["errorCode", "message"],
        "properties": {
          "errorCode": { "type": "integer", "enum": [0], "description": "成功为 0（RET_OK）" },
          "data": { "description": "业务数据" },
          "message": { "type": "string", "description": "成功时通常为空串" }
        }
      },
      "EnvelopeError": {
        "type": "object",
        "required": ["errorCode", "message"],
        "properties": {
          "errorCode": {
            "type": "integer",
            "description": "非 0；参数类常见为 100（RET_INVALID_PARAM），见 `common/consts/response_const.py`"
          },
          "data": { "nullable": true },
          "message": { "type": "string" },
          "detail": { "type": "string" },
          "_req_id": { "type": "string" }
        }
      },
      "AccessKey": {
        "type": "string",
        "minLength": 1,
        "description": "调用方 Access Key。服务端在 `sf_config.reg` 中按 `access_key` 与 **status=1（启用）** 解析；未匹配或非启用返回错误（message 如 invalid or inactive access_key）。"
      },
      "ConfigKey": {
        "type": "string",
        "minLength": 1,
        "maxLength": 191,
        "description": "配置业务键，对应表 `config_entry.config_key`。"
      },
      "ConfigPriRequestBody": {
        "type": "object",
        "required": ["key"],
        "properties": {
          "key": { "$ref": "#/components/schemas/ConfigKey" },
          "conditions": {
            "type": "object",
            "additionalProperties": true,
            "description": "可选。须为 JSON 对象；缺省按 `{}` 处理。用于与 **public=0** 行的 `config_entry.condition` 匹配（public=1 行不使用）。"
          }
        }
      },
      "ConfigQueryResultPub": {
        "type": "object",
        "required": ["value", "_ids"],
        "properties": {
          "value": {
            "description": "合并后的 JSON 值；无有效行或值均无法解析时可为 null",
            "nullable": true
          },
          "_ids": {
            "type": "string",
            "description": "参与合并的 `config_entry.id`，按合并顺序逗号分隔；无命中时为空串",
            "example": "12,45"
          }
        }
      },
      "ConfigQueryResult": {
        "type": "object",
        "required": ["value", "_ids", "_explain"],
        "properties": {
          "value": {
            "description": "合并后的 JSON 值；无有效行或值均无法解析时可为 null",
            "nullable": true
          },
          "_ids": {
            "type": "string",
            "description": "参与合并的 `config_entry.id`，按合并顺序逗号分隔；无命中时为空串",
            "example": "12,45"
          },
          "_explain": { "$ref": "#/components/schemas/ConfigQueryExplain" }
        }
      },
      "ConfigQueryExplain": {
        "type": "object",
        "required": ["conditions_received", "matched_layers"],
        "properties": {
          "conditions_received": {
            "type": "object",
            "additionalProperties": true,
            "description": "本次请求使用的 `conditions` 副本（与校验一致）"
          },
          "matched_layers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ConfigMatchedLayer" },
            "description": "按合并顺序排列的命中层审计信息"
          }
        }
      },
      "ConfigMatchedLayer": {
        "type": "object",
        "required": ["config_id", "row_condition", "condition_keys", "satisfied_by_request"],
        "properties": {
          "config_id": { "type": "integer", "description": "`config_entry` 主键" },
          "row_condition": {
            "type": "object",
            "additionalProperties": true,
            "description": "审计用条件快照；**public=1** 行不按条件合并，此处为 `{}`；**public=0** 行为解析后的 `condition`。"
          },
          "condition_keys": {
            "type": "array",
            "items": { "type": "string" },
            "description": "`row_condition` 键名排序列表"
          },
          "satisfied_by_request": {
            "type": "object",
            "additionalProperties": true,
            "description": "本行条件键在 `conditions_received` 中的取值快照"
          }
        }
      }
    }
  }
}
