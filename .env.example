APP_NAME=serv-fd

RUN_ENV=dev
DEBUG=True

# Server bind address and port (used by runserver, run.sh)
HOST=0.0.0.0
PORT=8000

# Default Cache-Control max-age (seconds) when ``@http_response_client_cache`` / ``@http_response_client_cache()``;
# use ``@http_response_client_cache(300)`` to override per view (does not change this env var).
HTTP_RESPONSE_CACHE_MAX_AGE_SECONDS=5

# runserver autoreload uses a second process; true | false only. true saves RAM when many instances share one host.
# Docker entrypoint defaults to true unless you override. Local dev: false for auto-reload.
DJANGO_RUNSERVER_NORELOAD=false


ALLOWED_HOSTS=*


# App Enable Switches (true/false)
# Control which apps are loaded at runtime
APP_CONSOLE_ENABLED=true
APP_AIBROKER_ENABLED=true
APP_CDN_ENABLED=true
APP_CMS_ENABLED=true
APP_CONFIG_ENABLED=true
APP_KEEPCON_ENABLED=true
APP_KNOW_ENABLED=true
APP_MAILSERVER_ENABLED=false
APP_NOTICE_ENABLED=true
APP_OSS_ENABLED=true
APP_SAGA_ENABLED=true
APP_SEARCHREC_ENABLED=true
APP_SNOWFLAKE_ENABLED=true
APP_TCC_ENABLED=true
APP_USER_ENABLED=true
APP_VERIFY_ENABLED=true


# Application Configurations
# AI Broker
AIBROKER_SERVICE_URL=http://localhost:8000/api/ai
AIBROKER_OSS_ENDPOINT=http://localhost:8000/api/oss
AIBROKER_OSS_BUCKET=ai
AIBROKER_OSS_MAX_BYTES_PER_FILE=20971520
# Console「调试」页发送时写入 call_log 的 reg_id（须与 aibroker 库中 reg 表主键一致）
AIBROKER_REG_ID_TEST=1
# Console「调试」页视频模型查询结果使用的 ai_provider 主键（该 provider.url_path 需包含 :task_id）
AI_PROVIDER_ID_GET_VIDEO=5
# prompt templates
PROMPT_TEMPLATE_ID_ASK_AND_ANSWER=7
PROMPT_TEMPLATE_ID_SUMMARY=0
PROMPT_TEMPLATE_ID_RELATION_EXTRACT=0

# CDN
CDN_CACHE_BUCKET=cdn-cache

# Config
CONFIG_CACHE_REDIS_KEY_PREFIX=cfg
CONFIG_CACHE_TTL_SECONDS=300

# Console
CONSOLE_AIBROKER_ACCESS_KEY=
CONSOLE_SEARCHREC_ACCESS_KEY=
CONSOLE_SNOWFLAKE_ACCESS_KEY=

# Keepcon
KEEPCON_CACHE_REDIS_DB=2
KEEPCON_CACHE_REDIS_KEY_PREFIX=kpcon

# Knowledge
# component similarity threshold (0.0-1.0, default 0.99)
KNOW_SIMILARITY_REUSE_THRESHOLD=0.99
KNOW_AIBROKER_ACCESS_KEY=

# Notice — wecom 酱 (Server酱 Turbo); SendKey for API path
NOTICE_BROKER_JIANG_URL=https://sctapi.ftqq.com
NOTICE_BROKER_JIANG_SEND_KEY=
# 控制台手动发送通知时默认 event_id
NOTICE_CONSOLE_MANUAL_EVENT_ID=1
# Max concurrent fire-and-forget notice sends per Gunicorn/uWSGI worker process
NOTICE_SEND_THREAD_POOL_MAX_WORKERS=8

# OSS
OSS_STORAGE_PATH=storage/oss
OSS_BUCKET_NAME=default
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600

# Saga
SAGA_SNOWFLAKE_ACCESS_KEY=
SAGA_SNOWFLAKE_ID_URL=

# SearchRec
SEARCHREC_MERGE_VECTOR_CANDIDATES=true
SEARCHREC_SEARCH_CANDIDATE_MULTIPLIER=2
SEARCHREC_DEFAULT_TOP_K=10
SEARCHREC_HTTP_TIMEOUT=3
# opensearch
SEARCHREC_OPENSEARCH_ENABLED=false
SEARCHREC_OPENSEARCH_URL=
SEARCHREC_OPENSEARCH_INDEX=searec_doc
SEARCHREC_OPENSEARCH_API_KEY=
# milvus
SEARCHREC_MILVUS_ENABLED=false
SEARCHREC_MILVUS_ENDPOINT=
SEARCHREC_MILVUS_COLLECTION=searec_vec
SEARCHREC_MILVUS_API_KEY=
# qdrant
SEARCHREC_QDRANT_ENABLED=false
SEARCHREC_QDRANT_URL=
SEARCHREC_QDRANT_COLLECTION=searec_vec
SEARCHREC_QDRANT_API_KEY=
# feast
SEARCHREC_FEAST_ENABLED=false
SEARCHREC_FEAST_ONLINE_URL=
SEARCHREC_FEAST_API_KEY=

# Snowflake
SNOWFLAKE_DATACENTER_ID=0
SNOWFLAKE_MACHINE_ID=0
SNOWFLAKE_START_TIMESTAMP=1609459200000
SNOWFLAKE_CLOCK_BACKWARD_THRESHOLD=5

# TCC / app_tcc (requires APP_TCC_ENABLED=true; create DB sf_tcc and migrate)
TCC_SNOWFLAKE_ACCESS_KEY=
# POST JSON {access_key} — full URL required (no implicit localhost)
TCC_SNOWFLAKE_ID_URL=
TCC_PHASE_TRY_TIMEOUT_SECONDS=120
TCC_PHASE_CONFIRM_TIMEOUT_SECONDS=120
TCC_PHASE_CANCEL_TIMEOUT_SECONDS=120
TCC_AWAIT_CONFIRM_TIMEOUT_SECONDS=300
TCC_MAX_AUTO_RETRIES=10
TCC_DEFAULT_AUTO_CONFIRM=true
TCC_OUTBOUND_TIMEOUT_SEC=30
TCC_SNOWFLAKE_HTTP_TIMEOUT_SEC=10
TCC_SCAN_PHASE_DEADLINE_FALLBACK_MS=60000
TCC_SCAN_NEXT_RETRY_CAP_MS=15000

# User Center (avatar: HTTP PUT to S3-compatible OSS only)
USER_OSS_ENDPOINT=http://localhost:8000/api/oss
USER_OSS_BUCKET=user
USER_VERIFY_ACCESS_KEY=
USER_NOTICE_ACCESS_KEY=
# login control
USER_CACHE_REDIS_DB=1
USER_CACHE_REDIS_KEY_PREFIX=user
# rate limit on login
USER_LOGIN_FAIL_MAX_ATTEMPTS_LOGIN_KEY=5
USER_LOGIN_FAIL_WINDOW_SECONDS=900
USER_LOGIN_FAIL_MAX_ATTEMPTS_IP=20
# rate limit on disposition blocks
USER_DISPOSITION_AUTH_THROTTLE_WINDOW_SECONDS=300
USER_DISPOSITION_AUTH_THROTTLE_MAX=30

# Verification
VERIFY_REQUEST_URL=http://localhost:8000/api/verify/request
VERIFY_CHECK_URL=http://localhost:8000/api/verify/check
VERIFY_CODE_TTL_SECONDS=300


# Thread pools
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_DEFAULT_QUEUE=default


# HTTPX global/client pools
HTTPX_DEFAULT_MAX_CONNECTIONS=100
HTTPX_DEFAULT_MAX_KEEPALIVE=20
HTTPX_DEFAULT_KEEPALIVE_EXPIRY=30
HTTPX_DEFAULT_TIMEOUT=30
HTTPX_WEBHOOK_MAX_CONNECTIONS=64
HTTPX_THIRD_PARTY_MAX_CONNECTIONS=64


# Test
TEST_SNOWFLAKE_ACCESS_KEY=


# MySQL
DB_DEFAULT_HOST=mysql
DB_DEFAULT_PORT=3306
DB_DEFAULT_NAME=sf
DB_DEFAULT_USER=zhang
DB_DEFAULT_PASS=123456

DB_AIBROKER_HOST=mysql
DB_AIBROKER_PORT=3306
DB_AIBROKER_NAME=sf_ai
DB_AIBROKER_USER=zhang
DB_AIBROKER_PASS=123456

DB_CDN_HOST=mysql
DB_CDN_PORT=3306
