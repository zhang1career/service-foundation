APP_NAME=serv-fd

RUN_ENV=dev
DEBUG=True

# Server bind address and port (used by runserver, run.sh)
HOST=0.0.0.0
PORT=8000


ALLOWED_HOSTS=*


# App Enable Switches (true/false)
# Control which apps are loaded at runtime
APP_CONSOLE_ENABLED=true
APP_AIBROKER_ENABLED=true
APP_CDN_ENABLED=true
APP_KNOW_ENABLED=true
APP_MAILSERVER_ENABLED=false
APP_NOTICE_ENABLED=true
APP_OSS_ENABLED=true
APP_SNOWFLAKE_ENABLED=true
APP_USER_ENABLED=true
APP_VERIFY_ENABLED=true


# Application Configurations
# AI Broker
AIBROKER_SERVICE_URL=http://localhost:8000/api/aibroker
# Embeddings: app_know TextHelper → HTTP broker /v1/embeddings; register ai_model capability=3 (e.g. text-embedding-3-small)
AIGC_EMBEDDING_DIMENSIONS=384

# CDN
CDN_CACHE_BUCKET=cdn-cache

# Knowledge
# component similarity threshold (0.0-1.0, default 0.99)
KNOW_SIMILARITY_REUSE_THRESHOLD=0.99
KNOW_AIBROKER_ACCESS_KEY=

# Notice

# OSS
OSS_STORAGE_PATH=storage/oss
OSS_BUCKET_NAME=default
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600

# Snowflake
SNOWFLAKE_DATACENTER_ID=0
SNOWFLAKE_MACHINE_ID=0
SNOWFLAKE_START_TIMESTAMP=1609459200000
SNOWFLAKE_CLOCK_BACKWARD_THRESHOLD=5

# User Center (avatar: HTTP PUT to S3-compatible OSS only)
USER_AVATAR_OSS_ENDPOINT=http://localhost:8000/api/oss
USER_AVATAR_OSS_BUCKET=user-avatar
USER_VERIFY_ACCESS_KEY=
USER_NOTICE_ACCESS_KEY=

# Verification
VERIFY_REQUEST_URL=http://localhost:8000/api/verify/request
VERIFY_CHECK_URL=http://localhost:8000/api/verify/check


# MySQL
DB_DEFAULT_HOST=mysql
DB_DEFAULT_PORT=3306
DB_DEFAULT_NAME=sf
DB_DEFAULT_USER=zhang
DB_DEFAULT_PASS=123456

DB_AIBROKER_HOST=mysql
DB_AIBROKER_PORT=3306
DB_AIBROKER_NAME=sf_ai
DB_AIBROKER_USER=zhang
DB_AIBROKER_PASS=123456

DB_CDN_HOST=mysql
DB_CDN_PORT=3306
DB_CDN_NAME=sf_cdn
DB_CDN_USER=zhang
DB_CDN_PASS=123456

DB_KNOW_HOST=mysql
DB_KNOW_PORT=3306
DB_KNOW_NAME=sf_know
DB_KNOW_USER=zhang
DB_KNOW_PASS=123456

DB_MAILSERVER_HOST=mysql
DB_MAILSERVER_PORT=3306
DB_MAILSERVER_NAME=sf_mailserver
DB_MAILSERVER_USER=zhang
DB_MAILSERVER_PASS=123456

DB_NOTICE_HOST=mysql
DB_NOTICE_PORT=3306
DB_NOTICE_NAME=sf_notice
DB_NOTICE_USER=zhang
DB_NOTICE_PASS=123456

DB_OSS_HOST=mysql
DB_OSS_PORT=3306
DB_OSS_NAME=sf_oss
DB_OSS_USER=zhang
DB_OSS_PASS=123456

DB_SNOWFLAKE_HOST=mysql
DB_SNOWFLAKE_PORT=3306
DB_SNOWFLAKE_NAME=sf_snowflake
DB_SNOWFLAKE_USER=zhang
DB_SNOWFLAKE_PASS=123456

DB_USER_HOST=mysql
DB_USER_PORT=3306
DB_USER_NAME=sf_user
DB_USER_USER=zhang
DB_USER_PASS=123456

DB_VERIFY_HOST=mysql
DB_VERIFY_PORT=3306
DB_VERIFY_NAME=sf_verify
DB_VERIFY_USER=zhang
DB_VERIFY_PASS=123456

# Mongo
MONGO_ATLAS_USER=your_mongo_user
MONGO_ATLAS_PASS=your_mongo_password
MONGO_ATLAS_HOST=your_cluster_id.mongodb.net
MONGO_ATLAS_CLUSTER=cluster0
MONGO_ATLAS_DB=know

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password
NEO4J_DATABASE=neo4j


# aigc
AIGC_API_URL=https://api2.aigcbest.top/v1
AIGC_API_KEY=your_key
AIGC_GPT_MODEL=gpt-5
AIGC_EMBEDDING_MODEL=text-embedding-3-small


# Log
LOG_HANDLER=logfile
LOG_LEVEL=INFO
# Relative: <project>/log/<APP_NAME>/app.log. In Docker set LOG_FILE_PATH=/var/log/serv-fd to match volume (e.g. docker-lab ./log/serv-fd)
LOG_FILE_PATH=log
LOG_FILE=app.log
# docker-entrypoint mail_server.log; in Docker set LOG_DIR=/var/log/serv-fd to match the same volume as LOG_FILE_PATH
# LOG_DIR=/var/log/serv-fd

LOG_LEVEL_DJANGO_DB=WARNING
LOG_LEVEL_APP_SERV_FD=INFO
LOG_LEVEL_APP_AIBROKER=INFO
LOG_LEVEL_APP_CDN=INFO
LOG_LEVEL_APP_KNOW=INFO
LOG_LEVEL_APP_MAILSERVER=INFO
LOG_LEVEL_APP_NOTICE=INFO
LOG_LEVEL_APP_OSS=INFO
LOG_LEVEL_APP_SNOWFLAKE=INFO
LOG_LEVEL_APP_USER=INFO
LOG_LEVEL_APP_VERIFY=INFO
LOG_LEVEL_COMMON=INFO